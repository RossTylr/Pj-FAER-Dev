for _candidate in [
    os.path.join(os.path.abspath('.'), 'src'),
    os.path.join(os.path.abspath('..'), '..', 'src'),
    os.path.join(os.path.abspath('..'), 'src'),
]:
    if os.path.isdir(_candidate) and _candidate not in sys.path:
        sys.path.insert(0, _candidate)
